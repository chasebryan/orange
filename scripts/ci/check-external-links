#!/bin/bash -p

set -euo pipefail

if [[ $# -ne 1 || -z "${1-}" ]]; then
  echo "usage: check-external-links PATH_TO_LYCHEE" >&2
  exit 2
fi
if [[ "$1" != /* ]]; then
  echo "PATH_TO_LYCHEE must be absolute" >&2
  exit 2
fi
if [[ ! -f "$1" || ! -s "$1" || ! -x "$1" || -L "$1" ]]; then
  echo "PATH_TO_LYCHEE must be a nonempty executable regular file" >&2
  exit 2
fi
if [[ "$(/usr/bin/stat --format='%a:%h' -- "$1")" != "755:1" ]]; then
  echo "PATH_TO_LYCHEE must have mode 0755 and one link" >&2
  exit 2
fi

readonly LYCHEE="$1"
readonly MAXIMUM_HOST_CONCURRENCY="2"
readonly MAXIMUM_RETRIES="3"
readonly MAXIMUM_TOTAL_CONCURRENCY="16"
readonly REQUEST_TIMEOUT_SECONDS="20"

# IACR ePrint currently rejects automated clients with HTTP 403. Keep its
# primary-source citations, exclude only that exact HTTPS host from automation,
# and review those links manually when research evidence is refreshed.
exec -- /usr/bin/env \
  --ignore-environment \
  -- \
  LANG=C \
  LC_ALL=C \
  PATH=/usr/bin:/bin \
  TZ=UTC \
  "$LYCHEE" \
  --exclude '^https://eprint\.iacr\.org/' \
  --exclude-all-private \
  --extensions md,yml \
  --host-concurrency "$MAXIMUM_HOST_CONCURRENCY" \
  --include-fragments \
  --max-concurrency "$MAXIMUM_TOTAL_CONCURRENCY" \
  --max-retries "$MAXIMUM_RETRIES" \
  --no-progress \
  --require-https \
  --timeout "$REQUEST_TIMEOUT_SECONDS" \
  -- \
  . '.github/**/*.md' '.github/**/*.yml'
