#!/bin/sh -p

set -eu

SCRIPT_PATH="$0"
case "$SCRIPT_PATH" in
  /*) ;;
  *) SCRIPT_PATH="./$SCRIPT_PATH" ;;
esac
readonly SCRIPT_PATH
if [ -L "$SCRIPT_PATH" ]; then
  echo "check-repository must not be invoked through a symbolic link" >&2
  exit 1
fi
if [ "$(find "$SCRIPT_PATH" -prune -links 1 -print)" != "$SCRIPT_PATH" ]; then
  echo "check-repository must not be invoked through a hard link" >&2
  exit 1
fi
readonly SCRIPT_DIRECTORY="$(CDPATH= cd -- "${SCRIPT_PATH%/*}" && pwd -P)"
readonly REPOSITORY_ROOT="$(cd -- "$SCRIPT_DIRECTORY/../.." && pwd -P)"

cd -- "$REPOSITORY_ROOT"

export LANG=C
export LC_ALL=C
export SOURCE_DATE_EPOCH=0
export TZ=UTC

exec env \
  -u BASH_ENV \
  -u ENV \
  -u GNUMAKEFLAGS \
  -u MAKEFLAGS \
  -u MAKEFILES \
  -u MAKEOVERRIDES \
  -u MFLAGS \
  make --no-builtin-rules --no-builtin-variables check
