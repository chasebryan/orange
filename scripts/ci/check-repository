#!/bin/sh -p

set -eu

if [ "$#" -ne 0 ]; then
  echo "usage: check-repository" >&2
  exit 2
fi

SCRIPT_PATH="$0"
case "$SCRIPT_PATH" in
  /*) ;;
  *) SCRIPT_PATH="./$SCRIPT_PATH" ;;
esac
readonly SCRIPT_PATH
if [ -L "$SCRIPT_PATH" ]; then
  echo "check-repository must not be invoked through a symbolic link" >&2
  exit 1
fi
if [ "$(/usr/bin/find "$SCRIPT_PATH" -prune -links 1 -print)" != "$SCRIPT_PATH" ]; then
  echo "check-repository must not be invoked through a hard link" >&2
  exit 1
fi
readonly SCRIPT_DIRECTORY="$(CDPATH= cd -- "${SCRIPT_PATH%/*}" && pwd -P)"
readonly REPOSITORY_ROOT="$(cd -- "$SCRIPT_DIRECTORY/../.." && pwd -P)"

cd -- "$REPOSITORY_ROOT"

ACCOUNT_RECORD="$(/usr/bin/getent passwd "$(/usr/bin/id -u)")" || {
  echo "cannot resolve the invoking operating-system account" >&2
  exit 1
}
case "$ACCOUNT_RECORD" in
  *'
'*)
    echo "invoking operating-system account is ambiguous" >&2
    exit 1
    ;;
esac
readonly ACCOUNT_RECORD
ACCOUNT_HOME="$(printf '%s\n' "$ACCOUNT_RECORD" | /usr/bin/cut -d: -f6)"
case "$ACCOUNT_HOME" in
  /*) ;;
  *)
    echo "invoking operating-system account has no absolute home directory" >&2
    exit 1
    ;;
esac
ACCOUNT_HOME="$(CDPATH= cd -- "$ACCOUNT_HOME" && pwd -P)" || {
  echo "cannot resolve the invoking operating-system account home" >&2
  exit 1
}
readonly ACCOUNT_HOME
readonly SAFE_PATH="$ACCOUNT_HOME/.cargo/bin:/usr/local/bin:/usr/bin:/bin"

exec /usr/bin/env \
  -i \
  HOME="$ACCOUNT_HOME" \
  LANG=C \
  LC_ALL=C \
  PATH="$SAFE_PATH" \
  SOURCE_DATE_EPOCH=0 \
  TZ=UTC \
  /usr/bin/make --no-builtin-rules --no-builtin-variables check
