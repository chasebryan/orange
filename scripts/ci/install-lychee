#!/bin/bash -p

set -euo pipefail

readonly PATH="/usr/bin:/bin"
export PATH
unset GZIP TAR_OPTIONS

readonly LYCHEE_VERSION="0.24.2"
readonly ARCHIVE="lychee-x86_64-unknown-linux-gnu.tar.gz"
readonly ARCHIVE_DIRECTORY="lychee-x86_64-unknown-linux-gnu"
readonly ARCHIVE_SHA256="1f4e0ef7f6554a6ed33dd7ac144fb2e1bbed98598e7af973042fc5cd43951c9a"
readonly DOWNLOAD_BASE="https://github.com/lycheeverse/lychee/releases/download/lychee-v${LYCHEE_VERSION}"
readonly MAXIMUM_ARCHIVE_BYTES="67108864"
readonly MAXIMUM_ARCHIVE_KIB="65536"
readonly MAXIMUM_DOWNLOAD_SECONDS="300"
readonly MAXIMUM_EXTRACTED_FILE_KIB="131072"

if [[ $# -ne 1 || -z "${1-}" ]]; then
  echo "usage: install-lychee DESTINATION_DIRECTORY" >&2
  exit 2
fi
if [[ "$1" != /* ]]; then
  echo "DESTINATION_DIRECTORY must be absolute" >&2
  exit 2
fi

if [[ "$(uname -s)" != "Linux" || "$(uname -m)" != "x86_64" ]]; then
  echo "install-lychee supports Linux x86_64 only" >&2
  exit 1
fi

readonly DESTINATION_DIRECTORY="$1"
TEMPORARY_DIRECTORY="$(/usr/bin/mktemp -d -- "${TMPDIR:-/tmp}/orange-lychee.XXXXXXXX")"
TEMPORARY_DIRECTORY="$(cd -- "$TEMPORARY_DIRECTORY" && pwd -P)"
readonly TEMPORARY_DIRECTORY
trap '/usr/bin/rm -rf -- "$TEMPORARY_DIRECTORY"' EXIT

(
  ulimit -c 0
  ulimit -f "$MAXIMUM_ARCHIVE_KIB"
  curl \
    --disable \
    --connect-timeout 20 \
    --fail \
    --location \
    --max-filesize "$MAXIMUM_ARCHIVE_BYTES" \
    --max-time "$MAXIMUM_DOWNLOAD_SECONDS" \
    --proto '=https' \
    --show-error \
    --silent \
    --tlsv1.2 \
    --output "$TEMPORARY_DIRECTORY/$ARCHIVE" \
    "$DOWNLOAD_BASE/$ARCHIVE"
)

printf '%s  %s\n' \
  "$ARCHIVE_SHA256" \
  "$TEMPORARY_DIRECTORY/$ARCHIVE" | sha256sum --check --strict

(
  ulimit -c 0
  ulimit -f "$MAXIMUM_EXTRACTED_FILE_KIB"
  tar \
    --extract \
    --file "$TEMPORARY_DIRECTORY/$ARCHIVE" \
    --gzip \
    --directory "$TEMPORARY_DIRECTORY" \
    --no-same-owner \
    --no-same-permissions \
    -- \
    "$ARCHIVE_DIRECTORY/lychee"
)

readonly EXTRACTED_FILE="$TEMPORARY_DIRECTORY/$ARCHIVE_DIRECTORY/lychee"
if [[ ! -f "$EXTRACTED_FILE" || ! -s "$EXTRACTED_FILE" || -L "$EXTRACTED_FILE" ]]; then
  echo "verified lychee archive did not contain a nonempty regular lychee executable" >&2
  exit 1
fi
if [[ "$(stat --format='%h' -- "$EXTRACTED_FILE")" != "1" ]]; then
  echo "verified lychee archive produced a hard-linked lychee executable" >&2
  exit 1
fi

install \
  -D \
  --no-target-directory \
  -m 0755 \
  -- \
  "$EXTRACTED_FILE" \
  "$DESTINATION_DIRECTORY/bin/lychee"
