{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:orange:gate0:schema:evidence-manifest:0.1",
  "$comment": "Provisional non-product Gate 0 schema. This URN is a local, non-resolving identifier and does not reserve a public namespace.",
  "title": "Orange provisional Gate 0 evidence manifest 0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_status",
    "non_product",
    "manifest_id",
    "purpose",
    "reproducibility_level",
    "decision_refs",
    "created_from_revision",
    "files",
    "claim_refs",
    "trust_inventory_refs",
    "external_sources",
    "observations",
    "replay",
    "independent_reproductions",
    "limitations"
  ],
  "properties": {
    "schema_version": { "const": "0.1" },
    "record_status": { "const": "provisional_gate0" },
    "non_product": { "type": "boolean", "const": true },
    "manifest_id": {
      "type": "string",
      "pattern": "^urn:orange:gate0:evidence:[a-z0-9][a-z0-9._:-]{2,127}$"
    },
    "purpose": { "const": "gate0_decision_evidence" },
    "reproducibility_level": {
      "enum": [
        "replayable_method",
        "deterministic_decision_case",
        "independent_decision_reproduction"
      ]
    },
    "decision_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^(D-[0-9]{3}|OEP-[0-9]{4})$" }
    },
    "created_from_revision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/file" }
    },
    "claim_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^G0-CLAIM-[A-Z0-9][A-Z0-9._-]{2,63}$" }
    },
    "trust_inventory_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^G0-TRUST-[A-Z0-9][A-Z0-9._-]{2,63}$" }
    },
    "external_sources": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/externalSource" }
    },
    "observations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/observation" }
    },
    "replay": { "$ref": "#/$defs/replay" },
    "independent_reproductions": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/independentReproduction" }
    },
    "supersedes_manifest_digest": { "$ref": "#/$defs/digest" },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 2048 }
    }
  },
  "oneOf": [
    {
      "properties": {
        "reproducibility_level": { "const": "replayable_method" },
        "independent_reproductions": { "maxItems": 0 }
      }
    },
    {
      "properties": {
        "reproducibility_level": { "const": "deterministic_decision_case" },
        "independent_reproductions": { "maxItems": 0 }
      }
    },
    {
      "properties": {
        "reproducibility_level": { "const": "independent_decision_reproduction" },
        "independent_reproductions": { "minItems": 1 }
      }
    }
  ],
  "$defs": {
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": { "const": "sha256" },
        "value": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:)(?!\\.{1,2}(?:/|$))(?!.*(?:/\\.{1,2})(?:/|$))(?!.*//)(?!.*[\\u0000-\\u001f\\u007f])[^/\\\\](?:[^\\\\]*[^/\\\\])?$"
    },
    "workingDirectory": {
      "anyOf": [
        { "const": "." },
        { "$ref": "#/$defs/relativePath" }
      ]
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "role", "media_type", "digest", "byte_size", "executable"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "role": { "enum": ["source", "input", "output", "log", "proof", "configuration", "tool", "standard_archive"] },
        "media_type": { "type": "string", "pattern": "^[a-z0-9.+-]+/[a-zA-Z0-9.+-]+$" },
        "digest": { "$ref": "#/$defs/digest" },
        "byte_size": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "executable": { "type": "boolean" }
      }
    },
    "externalSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "source_uri", "retrieved_at", "digest", "archive_state", "rights_reference"],
      "properties": {
        "source_id": { "type": "string", "pattern": "^G0-SOURCE-[A-Z0-9][A-Z0-9._-]{2,63}$" },
        "source_uri": { "type": "string", "format": "uri" },
        "retrieved_at": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
        "digest": { "$ref": "#/$defs/digest" },
        "archive_state": { "enum": ["archived", "metadata_only", "acquisition_required"] },
        "archived_path": { "$ref": "#/$defs/relativePath" },
        "acquisition_instructions": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "rights_reference": { "type": "string", "minLength": 1, "maxLength": 1024 }
      },
      "oneOf": [
        {
          "required": ["archive_state", "archived_path"],
          "properties": { "archive_state": { "const": "archived" } },
          "not": { "required": ["acquisition_instructions"] }
        },
        {
          "required": ["archive_state", "acquisition_instructions"],
          "properties": { "archive_state": { "const": "metadata_only" } },
          "not": { "required": ["archived_path"] }
        },
        {
          "required": ["archive_state", "acquisition_instructions"],
          "properties": { "archive_state": { "const": "acquisition_required" } },
          "not": { "required": ["archived_path"] }
        }
      ]
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "digest", "acquisition"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 256 },
        "version": { "type": "string", "minLength": 1, "maxLength": 256 },
        "digest": { "$ref": "#/$defs/digest" },
        "acquisition": { "type": "string", "minLength": 1, "maxLength": 1024 }
      }
    },
    "randomness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "encoding", "value"],
      "properties": {
        "mode": { "enum": ["none", "fixed"] },
        "generator": { "type": "string", "minLength": 1, "maxLength": 256 },
        "generator_version": { "type": "string", "minLength": 1, "maxLength": 256 },
        "generator_digest": { "$ref": "#/$defs/digest" },
        "encoding": { "enum": ["none", "hex", "decimal", "named_fixture"] },
        "value": { "type": "string", "minLength": 1, "maxLength": 512 },
        "state_mapping": { "type": "string", "minLength": 1, "maxLength": 2048 }
      },
      "oneOf": [
        {
          "properties": {
            "mode": { "const": "none" },
            "encoding": { "const": "none" },
            "value": { "const": "not-used" }
          },
          "not": {
            "anyOf": [
              { "required": ["generator"] },
              { "required": ["generator_version"] },
              { "required": ["generator_digest"] },
              { "required": ["state_mapping"] }
            ]
          }
        },
        {
          "required": [
            "mode",
            "generator",
            "generator_version",
            "generator_digest",
            "encoding",
            "value",
            "state_mapping"
          ],
          "properties": {
            "mode": { "const": "fixed" }
          },
          "oneOf": [
            {
              "properties": {
                "encoding": { "const": "hex" },
                "value": { "pattern": "^(?:[0-9a-f]{2})+$" }
              }
            },
            {
              "properties": {
                "encoding": { "const": "decimal" },
                "value": { "pattern": "^(0|[1-9][0-9]*)$" }
              }
            },
            {
              "properties": {
                "encoding": { "const": "named_fixture" },
                "value": { "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" }
              }
            }
          ]
        }
      ]
    },
    "concurrency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "worker_count", "determinism"],
      "properties": {
        "mode": { "enum": ["serial", "deterministic_parallel", "pinned_limited"] },
        "worker_count": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "determinism": { "enum": ["verified", "limitation_recorded"] },
        "limitation": { "type": "string", "minLength": 1, "maxLength": 2048 }
      },
      "oneOf": [
        {
          "properties": {
            "mode": { "const": "serial" },
            "worker_count": { "const": 1 },
            "determinism": { "const": "verified" }
          },
          "not": { "required": ["limitation"] }
        },
        {
          "properties": {
            "mode": { "const": "deterministic_parallel" },
            "worker_count": { "type": "integer", "minimum": 2, "maximum": 9007199254740991 },
            "determinism": { "const": "verified" }
          },
          "not": { "required": ["limitation"] }
        },
        {
          "required": ["limitation"],
          "properties": {
            "mode": { "const": "pinned_limited" },
            "worker_count": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
            "determinism": { "const": "limitation_recorded" }
          }
        }
      ]
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observation_id", "kind", "expected", "status", "evidence_file_refs"],
      "properties": {
        "observation_id": { "type": "string", "pattern": "^G0-OBSERVATION-[A-Z0-9][A-Z0-9._-]{2,63}$" },
        "kind": {
          "enum": [
            "schema_validation",
            "test_run",
            "proof_check",
            "byte_equality",
            "semantic_agreement",
            "external_review",
            "repository_state",
            "other"
          ]
        },
        "expected": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "actual": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "status": { "enum": ["expected_only", "matched", "mismatched", "unresolved"] },
        "evidence_file_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/relativePath" }
        },
        "explanation": { "type": "string", "minLength": 1, "maxLength": 2048 }
      },
      "oneOf": [
        {
          "properties": { "status": { "const": "expected_only" } },
          "not": { "required": ["actual"] }
        },
        {
          "required": ["actual"],
          "properties": { "status": { "enum": ["matched", "mismatched"] } }
        },
        {
          "required": ["explanation"],
          "properties": { "status": { "const": "unresolved" } }
        }
      ]
    },
    "independentReproduction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reproduction_id",
        "reviewer_id",
        "performed_at",
        "environment",
        "source_manifest_digest",
        "expected_output_manifest_digest",
        "result",
        "differences"
      ],
      "properties": {
        "reproduction_id": { "type": "string", "pattern": "^G0-REPRODUCTION-[A-Z0-9][A-Z0-9._-]{2,63}$" },
        "reviewer_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "performed_at": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
        "environment": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "source_manifest_digest": { "$ref": "#/$defs/digest" },
        "expected_output_manifest_digest": { "$ref": "#/$defs/digest" },
        "observed_output_manifest_digest": { "$ref": "#/$defs/digest" },
        "result": { "enum": ["matched", "different", "unresolved"] },
        "differences": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 2048 }
        }
      },
      "oneOf": [
        {
          "required": ["observed_output_manifest_digest"],
          "properties": {
            "result": { "const": "matched" },
            "differences": { "maxItems": 0 }
          }
        },
        {
          "required": ["observed_output_manifest_digest"],
          "properties": {
            "result": { "const": "different" },
            "differences": { "minItems": 1 }
          }
        },
        {
          "properties": {
            "result": { "const": "unresolved" },
            "differences": { "minItems": 1 }
          }
        }
      ]
    },
    "replay": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "argv",
        "working_directory",
        "environment",
        "network",
        "randomness",
        "concurrency",
        "toolchains",
        "input_manifest_digest",
        "expected_output_manifest_digest",
        "expected_exit_code"
      ],
      "properties": {
        "argv": {
          "type": "array",
          "minItems": 1,
          "prefixItems": [
            { "type": "string", "minLength": 1, "maxLength": 4096 }
          ],
          "items": { "type": "string", "maxLength": 4096 }
        },
        "working_directory": { "$ref": "#/$defs/workingDirectory" },
        "environment": {
          "type": "object",
          "additionalProperties": false,
          "required": ["LANG", "LC_ALL", "SOURCE_DATE_EPOCH", "TZ", "additional_variables"],
          "properties": {
            "LANG": { "const": "C" },
            "LC_ALL": { "const": "C" },
            "SOURCE_DATE_EPOCH": { "type": "string", "pattern": "^(0|[1-9][0-9]{0,9})$" },
            "TZ": { "const": "UTC" },
            "additional_variables": {
              "type": "object",
              "patternProperties": {
                "^(?!(?:LANG|LC_ALL|SOURCE_DATE_EPOCH|TZ)$)[A-Za-z_][A-Za-z0-9_]*$": {
                  "type": "string",
                  "maxLength": 4096
                }
              },
              "additionalProperties": false
            }
          }
        },
        "network": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "allowed_hosts"],
          "properties": {
            "mode": { "const": "denied" },
            "allowed_hosts": { "type": "array", "maxItems": 0 }
          }
        },
        "randomness": { "$ref": "#/$defs/randomness" },
        "concurrency": { "$ref": "#/$defs/concurrency" },
        "toolchains": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/toolchain" }
        },
        "input_manifest_digest": { "$ref": "#/$defs/digest" },
        "expected_output_manifest_digest": { "$ref": "#/$defs/digest" },
        "expected_exit_code": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }
      }
    }
  }
}
